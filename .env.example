# ===== THE LATENT LOUNGE — configuration =====

# YOUR receiving wallet. Use a FRESH, dedicated address — not your main holdings.
# Every paid play sends USDC here.
PAY_TO_ADDRESS=0xYOUR_RECEIVING_WALLET

# Network: start on "base-sepolia" (testnet, fake money) then switch to "base" (mainnet, real USDC)
NETWORK=base-sepolia

# Price per game in USD (settled as USDC)
PRICE_PER_PLAY=$0.02

# Grandmaster tier (harder puzzles)
GRANDMASTER_PRICE=$0.10

# Tournament: top % of daily participants who make the honor roll
QUALIFY_PCT=25

# Premium: permanent engraved plaque on the patron wall
PLAQUE_PRICE=$1.00

# Facilitator. Testnet default below is free.
# For Base MAINNET use the Coinbase CDP facilitator — see README step 5.
FACILITATOR_URL=https://x402.org/facilitator

# Server port
PORT=4021


# Duels & oracle pricing
DUEL_POST_PRICE=$0.25
DUEL_ATTEMPT_PRICE=$0.05
ORACLE_PRICE=$0.05

# Rate limits (per IP per 5 minutes)
RATE_LIMIT_API=300
RATE_LIMIT_CHECK=60
